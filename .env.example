# Pawa - Discord Voice Recording Bot (env vars for razzorstack)
# These variables are used by docker-compose.pawa.yml and caddy/pawa.caddyfile
# Copy to the parent docker/.env or set them there

# Get from: https://discord.com/developers/applications (create a new app)
PAWA_BOT_TOKEN=your_pawa_bot_token_here
PAWA_VERSION=2.17.0-be7c1c2b
PAWA_FILE_FORMAT=mp3
PAWA_RECORDER_TYPE=QUEUE
PAWA_DB_NAME=pawa
# JVM memory limits (percentage of container memory limit)
PAWA_JVM_MIN_RAM=25
PAWA_JVM_MAX_RAM=75

# Host path for recordings storage
PAWA_RECORDINGS_PATH=/home/daffy/pawa-recordings

# Basic auth for pawa.razzormail.com file browser
# Generate hash with: docker exec caddy caddy hash-password --plaintext 'YOUR_PASSWORD'
PAWA_BASIC_AUTH_USER=razzor
PAWA_BASIC_AUTH_HASH=your_bcrypt_hash_here
