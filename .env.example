# Pawa - Discord Voice Recording Bot (env vars for razzorstack)
# These variables are used by docker-compose.pawa.yml
# Copy to the parent docker/.env or set them there

# Get from: https://discord.com/developers/applications (create a new app)
PAWA_BOT_TOKEN=your_pawa_bot_token_here
PAWA_VERSION=2.17.0-be7c1c2b
PAWA_FILE_FORMAT=mp3
PAWA_RECORDER_TYPE=QUEUE
PAWA_DB_NAME=pawa
# JVM memory limits (percentage of container memory limit)
PAWA_JVM_MIN_RAM=25
PAWA_JVM_MAX_RAM=75
